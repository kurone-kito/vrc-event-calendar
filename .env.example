# Docker Compose defaults
APP_PORT=3000
DB_BIND_HOST=127.0.0.1
DB_PORT=5432
POSTGRES_DB=vrc_event_calendar
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_SCHEMA=public
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
# Docker-network connection string used by the app container.
# Override the hostname to `127.0.0.1` when running Prisma commands from the
# host shell against the published database port.
DATABASE_URL=postgresql://postgres:postgres@db:5432/vrc_event_calendar?schema=public
